# Ports exposed on the VPS (avoid conflicts with other apps)
FLOWER_API_PORT=3111
FLOWER_WEB_PORT=3110
FLOWER_ADMIN_PORT=3112

# Public API base URL used by the browser clients
FLOWER_PUBLIC_API_URL=http://YOUR_VPS_IP:3111

# Existing Postgres instance (do not create a new container)
# Use host.docker.internal if the Postgres container publishes a port on the VPS.
DATABASE_URL=postgresql://USER:PASSWORD@rental_postgres:5432/flower_shop?schema=public
